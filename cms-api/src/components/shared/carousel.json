{
  "collectionName": "components_shared_carousels",
  "info": {
    "displayName": "carousel"
  },
  "options": {},
  "attributes": {
    "title": {
      "type": "string"
    },
    "orientation": {
      "type": "enumeration",
      "default": "horizontal",
      "enum": [
        "horizontal",
        "vertical"
      ]
    },
    "align": {
      "type": "enumeration",
      "default": "start",
      "enum": [
        "start",
        "center",
        "end"
      ]
    },
    "loop": {
      "type": "boolean",
      "default": false
    },
    "dragFree": {
      "type": "boolean",
      "default": false
    },
    "autoplay": {
      "type": "boolean",
      "default": false
    },
    "showNavigation": {
      "type": "boolean",
      "required": false,
      "default": false
    },
    "showDots": {
      "type": "boolean",
      "default": false
    },
    "slidesToScroll": {
      "type": "integer",
      "default": 1,
      "min": 1,
      "max": 10
    },
    "items": {
      "type": "component",
      "component": "shared.carousel-item",
      "repeatable": false
    }
  },
  "config": {}
}
